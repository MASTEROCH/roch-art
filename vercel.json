{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/rochai", "destination": "https://roch-ai.vercel.app/rochai" },
    { "source": "/rochai/:path*", "destination": "https://roch-ai.vercel.app/rochai/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
